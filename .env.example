# Valores exclusivamente locais e demonstrativos. Nunca adicione segredos reais aqui.
APP_NAME="Operacional Lokas MC"
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost:8000

APP_LOCALE=pt_BR
APP_FALLBACK_LOCALE=pt_BR
APP_FAKER_LOCALE=pt_BR
APP_MAINTENANCE_DRIVER=file
BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

# Banco local dedicado. Troque todas as credenciais fora do desenvolvimento.
DB_CONNECTION=mariadb
DB_HOST=127.0.0.1
DB_PORT=3307
DB_DATABASE=operacional_lokasmc
DB_USERNAME=operacional_local
DB_PASSWORD=operacional_local
DB_CHARSET=utf8mb4
DB_COLLATION=utf8mb4_unicode_ci

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_EXPIRE_ON_CLOSE=false
SESSION_ENCRYPT=true
SESSION_PATH=/
SESSION_DOMAIN=null
SESSION_COOKIE=operacional_lokasmc_session
SESSION_SECURE_COOKIE=false
SESSION_HTTP_ONLY=true
SESSION_SAME_SITE=lax
SESSION_PARTITIONED_COOKIE=false

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=database
CACHE_STORE=database

# Mailpit local: SMTP em 1025 e interface web em http://127.0.0.1:8025.
MAIL_MAILER=smtp
MAIL_SCHEME=null
MAIL_HOST=127.0.0.1
MAIL_PORT=1025
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="nao-responda@localhost"
MAIL_FROM_NAME="${APP_NAME}"

# Gere um segredo independente em produção quando passkeys estiverem habilitadas.
PASSKEYS_USER_HANDLE_SECRET=
VITE_APP_NAME="${APP_NAME}"
